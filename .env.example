# ── Jira ──────────────────────────────────────────────────────────────────────
# Your Atlassian account email
JIRA_EMAIL=you@laserhub.com

# Generate at: https://id.atlassian.net/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_jira_api_token_here

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Path to your Google service account JSON file (see setup guide in README)
GOOGLE_CREDENTIALS_FILE=credentials.json

# ── Claude API ────────────────────────────────────────────────────────────────
# Generate at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── SendGrid ──────────────────────────────────────────────────────────────────
# Generate at: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your_sendgrid_api_key_here

# A verified sender email in your SendGrid account
SENDGRID_FROM_EMAIL=you@yourdomain.com
